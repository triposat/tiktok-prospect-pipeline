# TikTok Prospect Pipeline - environment configuration
# Copy this file to `.env` and fill in your real API keys.
# The `.env` file is gitignored - never commit real secrets.

# Apify API token
# Get yours at: https://console.apify.com/account/integrations
# Format: apify_api_...
APIFY_TOKEN=apify_api_your_token_here

# Cohere API key (used for LLM prospect ranking)
# Get a free trial key at: https://dashboard.cohere.com/api-keys
# No credit card required. First 1,000 calls/month are free.
CO_API_KEY=your_cohere_key_here
